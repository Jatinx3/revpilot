# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Supabase Postgres connection string (Project Settings -> Database -> Connection string).
# Use the direct connection or the session pooler URI.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Live data site to scrape
DATA_SITE_URL=https://otel-hackathon-data-site.vercel.app

# Model: provider-prefixed id resolved in agent/build_agent.py.
#   openrouter:<vendor/model> -> OpenRouter gateway (recommended; e.g. google/gemini-2.5-flash)
#   google_genai:<model> / openai:<model> also work (resolved by init_chat_model)
# Dev/localhost: gemini-2.5-flash (cheap, fast). Deployed live review: switch to
# MODEL_ID=openrouter:google/gemini-2.5-pro (stronger reasoning + instruction-following).
MODEL_ID=openrouter:google/gemini-2.5-flash
# OpenRouter key (https://openrouter.ai/keys); add a few $ of credit for reliability
OPENROUTER_API_KEY=
# Google Gemini direct — only if MODEL_ID=google_genai:... (not needed for openrouter:)
# GOOGLE_API_KEY=

# Supabase Auth (Project Settings -> API). Anon key is public (shipped to the browser).
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon public key>
